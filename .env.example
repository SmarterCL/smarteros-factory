# ═══════════════════════════════════════════════════════════════════════════════
#  SMARTER OS v2026.3.7 - Variables de Entorno
# ═══════════════════════════════════════════════════════════════════════════════

# Telegram Bot Token (de @BotFather)
TELEGRAM_BOT_TOKEN=

# Tu Chat ID (de @userinfobot) - TU ID DE PEDRO
TELEGRAM_CHAT_ID=54101...

# ═══════════════════════════════════════════════════════════════════════════════
#  MERCADO PAGO CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Access Token (obtener en https://www.mercadopago.cl/developers/panel/credentials)
MP_ACCESS_TOKEN=APP_USR-...

# Client ID (opcional, para OAuth)
MP_CLIENT_ID=

# Client Secret (opcional, para OAuth)
MP_CLIENT_SECRET=

# URL Base API (no cambiar a menos que seas Mercado Pago Developer)
MP_BASE_URL=https://api.mercadopago.com

# Webhook URL (donde recibirás notificaciones)
MP_NOTIFICATION_URL=https://tu-dominio.cl/webhook/mercadopago

# ═══════════════════════════════════════════════════════════════════════════════
#  INSTRUCCIONES:
#  1. Copiar este archivo a .env
#  2. Rellenar TELEGRAM_BOT_TOKEN con tu token de @BotFather
#  3. Rellenar TELEGRAM_CHAT_ID con tu ID (54101...)
#  4. Obtener credenciales en: https://www.mercadopago.cl/developers/panel/credentials
#  5. Completar MP_ACCESS_TOKEN
#  6. NUNCA commitear .env a git
# ═══════════════════════════════════════════════════════════════════════════════
